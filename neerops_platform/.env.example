# NEEROps v9.0 - Example Environment Configuration
# Copy this to .env and customize for your environment

# ─────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────
DEBUG=False
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Event Bus (Redis)
# ─────────────────────────────────────────────────────────────
EVENT_BUS_TYPE=redis                    # mock | redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─────────────────────────────────────────────────────────────
# Secrets Management (Vault)
# ─────────────────────────────────────────────────────────────
VAULT_TYPE=hashicorp                    # mock | hashicorp
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=devtoken
VAULT_KV_PATH=secret/neerops

# ─────────────────────────────────────────────────────────────
# Observability (OpenTelemetry + Jaeger)
# ─────────────────────────────────────────────────────────────
OTEL_TYPE=jaeger                        # mock | jaeger
JAEGER_HOST=localhost
JAEGER_PORT=6831
JAEGER_SERVICE=neerops

# ─────────────────────────────────────────────────────────────
# Audit Logging (QLDB)
# ─────────────────────────────────────────────────────────────
QLDB_TYPE=mock                          # mock | aws
QLDB_LEDGER_NAME=neerops-ledger
QLDB_LOG_FILE=/var/log/neerops/qldb.jsonl

# ─────────────────────────────────────────────────────────────
# Container Registry
# ─────────────────────────────────────────────────────────────
REGISTRY_TYPE=mock                      # mock | ecr | harbor
# ECR Configuration
ECR_REGISTRY=123456789.dkr.ecr.us-east-1.amazonaws.com
ECR_REGION=us-east-1
# Harbor Configuration
HARBOR_REGISTRY=http://localhost:8080
HARBOR_USERNAME=admin
HARBOR_PASSWORD=Harbor12345

# ─────────────────────────────────────────────────────────────
# Kubernetes
# ─────────────────────────────────────────────────────────────
K8S_ENABLED=False
K8S_NAMESPACE=default
K8S_CONTEXT=

# ─────────────────────────────────────────────────────────────
# Deployment Configuration
# ─────────────────────────────────────────────────────────────
CANARY_TIMEOUT_MINUTES=45
CANARY_5_PERCENT_DURATION=5
CANARY_50_PERCENT_DURATION=5
GATE_P_SUCCESS_MIN=0.95
GATE_P_ROLLBACK_MAX=0.90

# ─────────────────────────────────────────────────────────────
# Healing Configuration
# ─────────────────────────────────────────────────────────────
HEALING_HEURISTIC_MIN=0.5
HEALING_RL_MIN=0.7
HEALING_EMBEDDING_MIN=0.92
HEALING_LOCAL_MIN=0.8
HEALING_LLM_MIN=0.85

# ─────────────────────────────────────────────────────────────
# RL Training Configuration
# ─────────────────────────────────────────────────────────────
RL_TRAINING_WINDOW_DAYS=7
RL_KL_DIVERGENCE_THRESHOLD=0.1
RL_SHADOW_DEPLOYMENT_HOURS=24

# ─────────────────────────────────────────────────────────────
# LLM Configuration
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=mock                       # mock | openai | claude
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
CLAUDE_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-3-opus
LLM_RATE_LIMIT_PER_MINUTE=3

# ─────────────────────────────────────────────────────────────
# Monitoring
# ─────────────────────────────────────────────────────────────
MONITOR_METRICS_WINDOW=20
ANOMALY_DETECTION_ENABLED=True

# ─────────────────────────────────────────────────────────────
# Supervisor
# ─────────────────────────────────────────────────────────────
SUPERVISOR_ENABLED=True
SUPERVISOR_CHECK_INTERVAL=5
SUPERVISOR_L5_HEARTBEAT_TIMEOUT=30

# ─────────────────────────────────────────────────────────────
# VCS Integration (GitHub / Bitbucket)
# ─────────────────────────────────────────────────────────────
VCS_TYPE=mock                           # mock | github | bitbucket
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
BITBUCKET_USERNAME=
BITBUCKET_PASSWORD=

# ─────────────────────────────────────────────────────────────
# Alerting
# ─────────────────────────────────────────────────────────────
ALERT_CHANNELS=log,slack                # log,slack,pagerduty
SLACK_WEBHOOK=https://hooks.slack.com/services/...
PAGERDUTY_TOKEN=

# ─────────────────────────────────────────────────────────────
# Feature Flags
# ─────────────────────────────────────────────────────────────
FEATURE_PROMPT_EVOLUTION=True
FEATURE_RL_TRAINING=True
FEATURE_META_LEARNING=True
FEATURE_ASYNC_MONITORING=True
